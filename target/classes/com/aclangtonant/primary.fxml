<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aclangtonant.PrimaryController">
   <children>
      <Label text="Primary View" />
      <Label alignment="CENTER" text="Width" />
      <TextField fx:id="widthInput" promptText="Width" text="15000" />
      <Label alignment="CENTER" prefHeight="24.0" prefWidth="47.0" text="Height" textAlignment="CENTER" />
      <TextField fx:id="heightInput" promptText="Height" text="10000" />
      <Label alignment="CENTER" prefHeight="24.0" prefWidth="47.0" text="Ants" textAlignment="CENTER" />
      <TextField fx:id="antsInput" promptText="Ants" text="1000000" />
      <Label alignment="CENTER" prefHeight="24.0" prefWidth="47.0" text="Threads" textAlignment="CENTER" />
      <TextField fx:id="threadsInput" promptText="Threads" text="30" />
      <Button fx:id="primaryButton" onAction="#startSimulation" text="Start Simulation" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>

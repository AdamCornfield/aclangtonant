<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aclangtonant.simulationPage">
    <children>
        <Label text="Secondary View" />
        <StackPane fx:id="canvasContainer" minWidth="0.0" minHeight="0.0" VBox.vgrow="ALWAYS">
            <children>
                <Canvas fx:id="canvas" managed="false" />
            </children>
        </StackPane>
        <Button text="Run Ant" onAction="#runAnt" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
